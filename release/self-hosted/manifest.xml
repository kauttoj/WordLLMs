<?xml version="1.0" encoding="UTF-8"?>
<!--
  WordLLMs Add-in Manifest
  Updated and validated: February 2026

  Key correctness notes:
  - Uses VersionOverridesV1_0 (the ONLY supported override schema for Word task pane add-ins) [2](https://github.com/OfficeDev/Office-Add-in-Commands/blob/master/AutoOpenTaskpane/README.md)
  - Uses HTTP for localhost self-hosting (allowed by Microsoft for sideloaded add-ins)
  - Host type for Word is "Document" (correct for Word) [1](https://www.groovypost.com/howto/enable-developer-tab-microsoft-office-ribbon/)
  - Add-in commands (ribbon button + ShowTaskpane) correctly configured
-->

<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!--
    Unique add-in ID.
    This GUID must remain constant for your users, or the add-in installs as a
    completely new add-in.
  -->
  <Id>6b20e031-8f8e-5e3b-8481-976c5a9c0bc3</Id>

  <!-- Version increases trigger update detection -->
  <Version>1.0.1.0</Version>

  <ProviderName>kauttoj</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <!-- Display name & description seen in UI -->
  <DisplayName DefaultValue="WordLLMs"/>
  <Description DefaultValue="Integrate the Power of AI directly into Word"/>

  <!--
    Required icons for add-in commands.
  -->
  <IconUrl DefaultValue="http://localhost:3000/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="http://localhost:3000/assets/icon-80.png"/>

  <!--
    SupportUrl is optional, recommended to point to GitHub issues.
    <SupportUrl DefaultValue="https://github.com/YOUR_REPO/issues"/>
  -->

  <!--
    AppDomains define allowed navigation targets from within task panes.
    Remove placeholder domains; leave empty if no cross-origin navigation occurs.
  -->
  <AppDomains>
  </AppDomains>

  <!--
    Declare host. For Word, the host is "Document". ✔ Correct. [1](https://www.groovypost.com/howto/enable-developer-tab-microsoft-office-ribbon/)
  -->
  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <!--
    Default task pane URL (fallback if commands not supported).
    HTTP localhost is allowed for sideloaded add-ins.
  -->
  <DefaultSettings>
    <SourceLocation DefaultValue="http://localhost:3000/index.html"/>
  </DefaultSettings>

  <!--
    Permission model: ReadWriteDocument is normal for task pane AI assistant.
  -->
  <Permissions>ReadWriteDocument</Permissions>

  <!--
    VersionOverrides section enables add-in commands on the ribbon.
    MUST use VersionOverridesV1_0 for Word/Excel/PowerPoint. [2](https://github.com/OfficeDev/Office-Add-in-Commands/blob/master/AutoOpenTaskpane/README.md)
  -->
  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Hosts>
      <Host xsi:type="Document">

        <DesktopFormFactor>

          <!--
            Optional "Getting Started" callout.
            Shown once after installation.
          -->
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>

          <!--
            FunctionFile: supports ExecuteFunction model.
            NOTE: commented out to prevent debug pop-up
          <FunctionFile resid="Commands.Url"/>
		  -->

          <!--
            PrimaryCommandSurface defines the ribbon UI extensions.
            Here we extend the Word "Home" tab.
          -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">

            <!-- Attach to existing "Home" tab -->
            <OfficeTab id="TabHome">

              <!-- Group containing your button -->
              <Group id="WordLLMs.CommandsGroup">
                <Label resid="CommandsGroup.Label"/>

                <!-- Ribbon icons -->
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- Ribbon button that opens the task pane -->
                <Control xsi:type="Button" id="WordLLMs.TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>

                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>

                  <!--
                    ShowTaskpane is the correct action type
                    for opening your main UI. ✔
                  -->
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>TaskPane.WordLLMs</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>

          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- Resource definitions: icons, strings, URLs -->
    <Resources>

      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="http://localhost:3000/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="http://localhost:3000/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="http://localhost:3000/assets/icon-80.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl"
                DefaultValue="https://go.microsoft.com/fwlink/?LinkId=276812"/>
        <bt:Url id="Commands.Url"
                DefaultValue="http://localhost:3000/commands.html"/>
        <bt:Url id="Taskpane.Url"
                DefaultValue="http://localhost:3000/index.html"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Get started with WordLLMs!"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="WordLLMs"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="WordLLMs"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="GetStarted.Description"
                   DefaultValue="Your add-in loaded successfully. Open the Home tab and click 'WordLLMs' to begin."/>
        <bt:String id="TaskpaneButton.Tooltip"
                   DefaultValue="Open the WordLLMs task pane"/>
      </bt:LongStrings>

    </Resources>

  </VersionOverrides>
</OfficeApp>